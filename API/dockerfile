# Etapa 1: Build do binário estático
FROM golang:1.25-alpine AS builder

# Instala dependências de compilação
RUN apk add --no-cache git

WORKDIR /app

# Copia arquivos de dependências primeiro (otimiza cache do Docker)
COPY go.mod go.sum ./
RUN go mod download

# Copia o restante do código da API
COPY . .

# Gera o binário estático (CGO_ENABLED=0) para rodar em qualquer imagem Linux
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o main ./cmd/main.go

# Etapa 2: Imagem final ultra-leve (Alpine)
FROM alpine:latest

# Certificados CA são necessários para conexões HTTPS (ex: Neon/Supabase)
RUN apk --no-cache add ca-certificates

WORKDIR /app

# Copia apenas o binário gerado na etapa anterior
COPY --from=builder /app/main .

# Expõe a porta padrão da API
EXPOSE 8080

# O comando de execução permite passar flags (como --migrate) via docker-compose
CMD ["./main"]
